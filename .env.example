# Copie para .env.local (não commitar). No Netlify: Site configuration → Environment variables.
# Modo de dados:
# - local: usa IndexedDB/Dexie (ideal para ajustar processo primeiro)
# - cloud: usa Supabase como fonte principal
VITE_DATA_MODE=local

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_publica

# Opcional — só depois de rodar o SQL correspondente no Supabase:
# supabase/sql/009_tasks_is_ad_hoc.sql
#VITE_SYNC_TASK_IS_AD_HOC=1
# supabase/sql/018_tasks_no_show_fields.sql (no-show + vínculo de reagendamento em tasks)
#VITE_SYNC_TASK_NO_SHOW_FIELDS=1
# supabase/sql/016_projects_manual_checkin.sql (check-in manual de projeto na nuvem)
#VITE_SYNC_PROJECT_MANUAL_CHECKIN=1
# Recuperação de senha: em Supabase → Authentication → URL Configuration, inclua em Redirect URLs:
# http://localhost:5173/auth/redefinir-senha (e a URL de produção com o mesmo path).
