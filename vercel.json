{
  "rewrites": [
    {
      "source": "/api/brasilapi/:path*",
      "destination": "https://brasilapi.com.br/:path*"
    },
    {
      "source": "/api/receitaws/:path*",
      "destination": "https://www.receitaws.com.br/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
